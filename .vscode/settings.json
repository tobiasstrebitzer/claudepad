{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/flutter/ephemeral": true,
    "**/Flutter/ephemeral": true,
    "**/.symlinks": true,
    "**/.plugin_symlinks": true,
    "**/node_modules": true,
    "**/test-results": true,
    "**/dist": true,
    "**/tsconfig.tsbuildinfo": true
  },
  "[jsonc]": {
    "editor.formatOnSave": false
  },
  "[scss]": {
    "editor.formatOnSave": false
  },
  "[html]": {
    "editor.formatOnSave": false
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "eslint.workingDirectories": [
    "apps/client"
  ],
  "editor.formatOnSave": true,
  "editor.rulers": [80],
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,
  "editor.trimAutoWhitespace": true,
  "eslint.nodePath": "./node_modules",
  "eslint.run": "onType",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "js/ts.preferences.quoteStyle": "single",
  "json.format.enable": false,
  "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,
  "js/ts.format.semicolons": "remove",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.updateImportsOnFileMove.enabled": "never",
  "js/ts.preferences.importModuleSpecifier": "relative"
}

{
  "name": "claudepad",
  "version": "0.5.0",
  "private": true,
  "description": "Turn a raw Claude Code session into a clean, shareable, end-to-end-encrypted artifact - entirely client-side.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && pnpm --filter @claudepad/client run lint && node scripts/check-no-raw-hex.mjs && node scripts/check-contrast.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:poc": "node poc/verify.mjs",
    "dev": "pnpm --filter @claudepad/client run dev",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run verify:poc"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.9"
  }
}

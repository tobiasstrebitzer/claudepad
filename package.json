{
  "name": "claudepad",
  "version": "0.14.0",
  "private": true,
  "description": "Turn a raw Claude Code session into a clean, shareable, end-to-end-encrypted artifact - entirely client-side.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "clean": "pnpm -r run clean",
    "build": "pnpm -r run build",
    "prepack": "pnpm -r run prepack",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm -r run lint && node scripts/check-no-raw-hex.mjs && node scripts/check-contrast.mjs",
    "verify:no-phone-home": "node scripts/check-no-external-origins.mjs",
    "dev": "pnpm --filter @claudepad/client run dev",
    "check": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "vite/client"],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src"],
  "references": [
    { "path": "../schema" },
    { "path": "../shared" },
    { "path": "../ingest" }
  ]
}

{
  "name": "@claudepad/registry-client",
  "version": "0.12.1",
  "private": true,
  "description": "Framework-agnostic client SDK for the registry contract (registry-spec.md): a fetch-based RegistryClient that works against ANY conformant registry (no hardwired URL), with the HTTPS-only guard enforced at connect. Implements RegistryProvider.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm clean && pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@claudepad/registry-spec": "workspace:*"
  },
  "devDependencies": {
    "@claudepad/registry": "workspace:*",
    "@claudepad/crypto": "workspace:*"
  }
}

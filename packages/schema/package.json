{
  "name": "@claudepad/schema",
  "version": "0.6.1",
  "private": true,
  "description": "Tolerant Claude Code JSONL parser and the normalized, source-agnostic Session model (PRD-02). Zero runtime dependencies; isomorphic (browser + Node).",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "fast-check": "^3.23.2"
  }
}

{
  "name": "@claudepad/shared",
  "version": "0.9.0",
  "private": true,
  "description": "Zero-dependency WebCrypto core (PRD-05): ECDH P-256, HKDF-SHA256, AES-256-GCM content/wrap encryption, recipient-wrapped sealed-box blobs, and key fingerprints. Isomorphic (browser + Node). Mirrors poc/.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./crypto": {
      "types": "./src/crypto/index.ts",
      "import": "./src/crypto/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
